# ─────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────
# OpenAI (AI features: Assistant, Coach, Roast, Receipt scan)
# ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────
# Paddle (Billing)
# Get these from your Paddle dashboard.
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
# Paddle price IDs for each plan
NEXT_PUBLIC_PADDLE_PRICE_PRO=pri_...
NEXT_PUBLIC_PADDLE_PRICE_PREMIUM=pri_...
NEXT_PUBLIC_PADDLE_PRICE_BUSINESS=pri_...

# ─────────────────────────────────────────────────────────
# Admin bootstrap (first admin). Change after first login.
# ─────────────────────────────────────────────────────────
ADMIN_BOOTSTRAP_EMAIL=admin@goalify.app
ADMIN_BOOTSTRAP_PASSWORD=change-this-now

# ─────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
